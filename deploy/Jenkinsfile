pipeline {
    agent any

    stages {

        stage("Initial cleanup") {
            steps {
                dir("${WORKSPACE}") {
                    deleteDir()
                }
            }
        }

        stage('Checkout SCM') {
            steps {
                git branch: 'main', url: 'https://github.com/NUELRL/php-todo'
            }
        }

        stage('Prepare Dependencies') {
            steps {

                sh '/usr/bin/php7.4 -v'

                sh 'mv .env.sample .env'

                sh '''
                sed -i 's/DB_HOST=.*/DB_HOST=172.31.36.195/' .env
                sed -i 's/DB_DATABASE=.*/DB_DATABASE=homestead/' .env
                sed -i 's/DB_USERNAME=.*/DB_USERNAME=homestead/' .env
                sed -i 's/DB_PASSWORD=.*/DB_PASSWORD=password/' .env
                '''

                // DEBUG
                sh 'cat .env'

                // INSTALL DEPENDENCIES FIRST (VERY IMPORTANT)
                sh 'composer install'

                // NOW artisan will work
                sh '/usr/bin/php7.4 artisan config:clear'
                sh '/usr/bin/php7.4 artisan cache:clear'
                sh 'rm -rf bootstrap/cache/*'

                sh '/usr/bin/php7.4 artisan key:generate'

                // DB operations
                sh '/usr/bin/php7.4 artisan migrate'
                sh '/usr/bin/php7.4 artisan db:seed'

                // Optional cache after success
                sh '/usr/bin/php7.4 artisan config:cache'
            }
        }
    }
}